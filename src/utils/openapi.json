{
  "openapi": "3.0.0",
  "info": {
    "title": "Arcyl Media API Documentation",
    "description": "Production-hardened REST API endpoints for Arcyl Media digital agency operations.",
    "version": "1.0.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Check System Health Status",
        "description": "Verifies connectivity to PostgreSQL via Prisma and checks Resend/Cloudinary config states.",
        "responses": {
          "200": {
            "description": "Health status response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/contact": {
      "post": {
        "summary": "Capture Public Form Inquiries",
        "description": "Validates inputs via Zod, checks rate limits, creates/matches lead records, logs system actions, and alerts admins and visitors via Resend.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Lead and Inquiry successfully logged",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactSuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Input validation failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limiting threshold exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateLimitErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Centralized database/system masked error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServerErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContactRequest": {
        "type": "object",
        "required": [
          "name",
          "email",
          "subject",
          "message"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Aditya Jain"
          },
          "email": {
            "type": "string",
            "example": "adityajain0322@gmail.com"
          },
          "phone": {
            "type": "string",
            "example": "+919876543210"
          },
          "subject": {
            "type": "string",
            "example": "AI Integration Quote"
          },
          "message": {
            "type": "string",
            "example": "I need a consulting quote for integrating LLMs into our pipeline."
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "System status check successful"
          },
          "data": {
            "type": "object",
            "properties": {
              "services": {
                "type": "object",
                "properties": {
                  "database": {
                    "type": "string",
                    "example": "connected"
                  },
                  "email": {
                    "type": "string",
                    "example": "configured"
                  },
                  "cloudinary": {
                    "type": "string",
                    "example": "unconfigured"
                  }
                }
              },
              "version": {
                "type": "string",
                "example": "0.1.0"
              },
              "uptime": {
                "type": "number",
                "example": 108.4
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "requestId": {
                "type": "string",
                "example": "373dbd63-5fb1-4322-992e-9962c328b21c"
              },
              "timestamp": {
                "type": "string",
                "example": "2026-06-28T13:42:00.000Z"
              }
            }
          }
        }
      },
      "ContactSuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Contact submission recorded successfully"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "example": "802854a0-5fb1-4c22-affc-985143bb4f7a"
              },
              "leadId": {
                "type": "string",
                "example": "9962c328-5fb1-4770-8db9-f48df6081f34"
              },
              "subject": {
                "type": "string",
                "example": "AI Integration Quote"
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "requestId": {
                "type": "string",
                "example": "373dbd63-5fb1-4322-992e-9962c328b21c"
              },
              "timestamp": {
                "type": "string",
                "example": "2026-06-28T13:42:00.000Z"
              }
            }
          }
        }
      },
      "ValidationErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Validation failed"
          },
          "data": {
            "type": "null"
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "VALIDATION_ERROR"
              },
              "details": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": {
                      "type": "string",
                      "example": "email"
                    },
                    "message": {
                      "type": "string",
                      "example": "Invalid email address format"
                    }
                  }
                }
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "requestId": {
                "type": "string",
                "example": "373dbd63-5fb1-4322-992e-9962c328b21c"
              },
              "timestamp": {
                "type": "string",
                "example": "2026-06-28T13:42:00.000Z"
              }
            }
          }
        }
      },
      "RateLimitErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Too many requests, please try again later"
          },
          "data": {
            "type": "null"
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "RATE_LIMIT_EXCEEDED"
              },
              "details": {
                "type": "null"
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "requestId": {
                "type": "string",
                "example": "373dbd63-5fb1-4322-992e-9962c328b21c"
              },
              "timestamp": {
                "type": "string",
                "example": "2026-06-28T13:42:00.000Z"
              }
            }
          }
        }
      },
      "ServerErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Internal Server Error"
          },
          "data": {
            "type": "null"
          },
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "INTERNAL_SERVER_ERROR"
              },
              "details": {
                "type": "null"
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "requestId": {
                "type": "string",
                "example": "373dbd63-5fb1-4322-992e-9962c328b21c"
              },
              "timestamp": {
                "type": "string",
                "example": "2026-06-28T13:42:00.000Z"
              }
            }
          }
        }
      }
    }
  }
}
