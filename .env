# Environment Settings
NODE_ENV="development"
LOG_LEVEL="info"

# Database Settings
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arcyl_media?schema=public"

# Authentication
JWT_SECRET="supersecretkeyreplaceinproduction12345!"
JWT_REFRESH_SECRET="supersecretrefreshkeyreplaceinproduction12345!"
JWT_EXPIRES_IN="7d"

# Resend Email Service Settings
RESEND_API_KEY="re_your_resend_api_key"
ADMIN_EMAIL="arcylmedia@gmail.com"
EMAIL_FROM="Arcyl Media <onboarding@resend.dev>"

# Cloudinary Storage Settings
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
