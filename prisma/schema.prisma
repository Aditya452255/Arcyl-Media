// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  SPAM
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique // e.g. Lead.Read
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model User {
  id           String        @id @default(uuid())
  name         String?
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]
  roles        UserRole[]
  mediaAssets  MediaAsset[]
  assignedLeads Lead[]       @relation("LeadAssignee")
  leadNotes    LeadNote[]
  notifications Notification[]

  // CMS edits tracking relations
  heroEdits        Hero[]
  aboutEdits       About[]
  serviceEdits     Service[]
  portfolioEdits   Portfolio[]
  testimonialEdits Testimonial[]
  faqEdits         FAQ[]
  techEdits        Technology[]
  teamEdits        TeamMember[]
  settingsEdits    SiteSetting[]
  socialEdits      SocialLink[]
  footerEdits      Footer[]
  widgets          DashboardWidget[]

  // Phase 4 relations
  managedProjects  Project[]         @relation("ProjectManager")
  projectFiles     ProjectFile[]     @relation("ProjectFileUploader")
  discussions      Discussion[]      @relation("DiscussionAuthor")
  discussionReplies DiscussionReply[] @relation("ReplyAuthor")
  calendarEvents   CalendarEvent[]   @relation("CalendarCreator")

  // Phase 5 relations
  assignedTasks     Task[]            @relation("TaskAssignee")
  createdTasks      Task[]            @relation("TaskCreator")
  updatedTasks      Task[]            @relation("TaskUpdater")
  taskComments      TaskComment[]

  // Phase 6 relations
  clientId          String?
  client            Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sentMessages      Message[]         @relation("MessageSender")

  @@map("users")
}

model Lead {
  id          String              @id @default(uuid())
  name        String
  email       String              @unique
  phone       String?
  company     String?
  status      LeadStatus          @default(NEW)
  isArchived  Boolean             @default(false)
  assigneeId  String?
  assignee    User?               @relation("LeadAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  notes       LeadNote[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  submissions ContactSubmission[]

  @@map("leads")
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@map("lead_notes")
}

model ContactSubmission {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_submissions")
}

model ActivityLog {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String
  details       Json
  ipAddress     String?
  userAgent     String?
  requestId     String?  // request lifecycle ID
  previousValue Json?
  newValue      Json?
  resource      String?  // target resource (e.g. Employee, CMS block)
  createdAt     DateTime @default(now())

  @@map("activity_logs")
}

model MediaAsset {
  id             String   @id @default(uuid())
  url            String
  publicId       String   @unique
  fileType       String   // image, video, raw
  mimeType       String
  size           Int
  folder         String?
  altText        String?
  tags           Json?    // tags list
  collectionName String?  // group collections
  version        Int      @default(1)
  isDeleted      Boolean       @default(false)
  uploadedById   String?
  uploadedBy     User?         @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  projectFiles   ProjectFile[]
  taskAttachments TaskAttachment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("media_assets")
}

// Agency Core Models

model Employee {
  id               String      @id @default(uuid())
  firstName        String
  lastName         String
  email            String      @unique
  phone            String?
  profilePhoto     String?
  bio              String?
  skills           Json?       // Skills array
  designation      String
  departmentId     String?
  department       Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id], onDelete: SetNull)
  joiningDate      DateTime
  employmentStatus String      @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED, TERMINATED
  github           String?
  linkedin         String?
  portfolioUrl     String?
  isDeleted        Boolean        @default(false)
  managedDept      Department?    @relation("DepartmentManager")
  projectMembers   ProjectMember[]
  timeEntries      TimeEntry[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("employees")
}

model Department {
  id        String     @id @default(uuid())
  name      String     @unique
  managerId String?    @unique
  manager   Employee?  @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees Employee[] @relation("DepartmentEmployees")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("departments")
}

model OrganizationSetting {
  id            String   @id @default(uuid())
  companyName   String
  logo          String?
  favicon       String?
  gst           String?
  pan           String?
  phone         String?
  emails        Json?    // list of contact emails
  address       String?
  currency      String   @default("USD")
  timezone      String   @default("UTC")
  language      String   @default("en")
  businessHours Json?
  socialLinks   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("organization_settings")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  category    String   // SMTP, CLOUDINARY, THEME, FEATURE_FLAG, etc.
  isEncrypted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  message    String
  type       String   // LEAD_CREATED, EMPLOYEE_ADDED, CMS_UPDATED, MEDIA_UPLOADED, USER_LOGIN, PERMISSION_CHANGED
  isRead     Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("notifications")
}

model DashboardWidget {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgetKey    String   // CRM_LEADS, OPERATIONAL_METRICS, etc.
  isVisible    Boolean  @default(true)
  displayOrder Int      @default(0)
  preferences  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, widgetKey])
  @@map("dashboard_widgets")
}

// CMS Models

model Hero {
  id                 String    @id @default(uuid())
  title              String
  subtitle           String?
  ctaText            String?
  ctaLink            String?
  backgroundImage    String?
  isPublished        Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  displayOrder       Int       @default(0)
  slug               String?   @unique
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String?
  updatedById        String?
  updatedBy          User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("cms_hero")
}

model About {
  id                 String    @id @default(uuid())
  title              String
  content            String
  image              String?
  isPublished        Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  displayOrder       Int       @default(0)
  slug               String?   @unique
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String?
  updatedById        String?
  updatedBy          User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("cms_about")
}

model Service {
  id                 String    @id @default(uuid())
  title              String
  description        String
  icon               String?
  isPublished        Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  displayOrder       Int       @default(0)
  slug               String    @unique
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String?
  updatedById        String?
  updatedBy          User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("cms_services")
}

model Portfolio {
  id                 String    @id @default(uuid())
  title              String
  description        String
  image              String?
  category           String?
  clientName         String?
  projectDate        String?
  ctaLink            String?
  isPublished        Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  displayOrder       Int       @default(0)
  slug               String    @unique
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String?
  updatedById        String?
  updatedBy          User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("cms_portfolio")
}

model Testimonial {
  id                 String    @id @default(uuid())
  author             String
  company            String?
  role               String?
  content            String
  image              String?
  rating             Int       @default(5)
  isPublished        Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  displayOrder       Int       @default(0)
  slug               String?   @unique
  updatedById        String?
  updatedBy          User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("cms_testimonials")
}

model FAQ {
  id                 String    @id @default(uuid())
  question           String
  answer             String
  isPublished        Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  displayOrder       Int       @default(0)
  slug               String?   @unique
  updatedById        String?
  updatedBy          User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("cms_faqs")
}

model Technology {
  id                 String    @id @default(uuid())
  name               String
  category           String?
  logo               String?
  isPublished        Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  displayOrder       Int       @default(0)
  slug               String?   @unique
  updatedById        String?
  updatedBy          User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("cms_technologies")
}

model TeamMember {
  id                 String    @id @default(uuid())
  name               String
  role               String
  bio                String?
  image              String?
  socialLinks        Json?
  isPublished        Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  displayOrder       Int       @default(0)
  slug               String?   @unique
  updatedById        String?
  updatedBy          User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("cms_team_members")
}

model SiteSetting {
  id                String   @id @default(uuid())
  logo              String?
  companyName       String
  email             String
  phone             String?
  address           String?
  businessHours     Json?
  socialLinks       Json?
  googleAnalyticsId String?
  metaTitle         String?
  metaDescription   String?
  openGraphImage    String?
  favicon           String?
  themeSettings     Json?
  updatedById       String?
  updatedBy         User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("cms_site_settings")
}

model SocialLink {
  id                 String    @id @default(uuid())
  platform           String
  url                String
  isPublished        Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  displayOrder       Int       @default(0)
  slug               String?   @unique
  updatedById        String?
  updatedBy          User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("cms_social_links")
}

model Footer {
  id                 String    @id @default(uuid())
  copyrightText      String
  links              Json?
  isPublished        Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  slug               String?   @unique
  updatedById        String?
  updatedBy          User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("cms_footer")
}

// ─────────────────────────────────────────────────────────
// Phase 4 — Client & Project Workspace
// ─────────────────────────────────────────────────────────

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  ARCHIVED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum DeliverableStatus {
  DRAFT
  SUBMITTED
  REVISION_REQUESTED
  APPROVED
  REJECTED
}

enum CalendarEventType {
  MEETING
  DEADLINE
  MILESTONE
  REMINDER
  BIRTHDAY
  OTHER
}

model Client {
  id          String          @id @default(uuid())
  companyName String
  logo        String?
  industry    String?
  website     String?
  gst         String?
  pan         String?
  address     String?
  timezone    String          @default("UTC")
  currency    String          @default("USD")
  status      ClientStatus    @default(ACTIVE)
  notes       String?
  isDeleted   Boolean         @default(false)
  isArchived  Boolean         @default(false)
  contacts    ClientContact[]
  projects    Project[]
  users       User[]
  quotes      Quote[]
  proposals   Proposal[]
  invoices    Invoice[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("clients")
}

model ClientContact {
  id                     String   @id @default(uuid())
  clientId               String
  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firstName              String
  lastName               String
  position               String?
  email                  String
  phone                  String?
  linkedin               String?
  birthday               DateTime?
  notes                  String?
  preferredContactMethod String?
  isDeleted              Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("client_contacts")
}

model Project {
  id           String          @id @default(uuid())
  name         String
  description  String?
  clientId     String?
  client       Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  managerId    String?
  manager      User?           @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)
  status       ProjectStatus   @default(PLANNING)
  priority     ProjectPriority @default(MEDIUM)
  budget       Float?
  startDate    DateTime?
  deadline     DateTime?
  progress     Int             @default(0)
  tags         Json?
  isDeleted    Boolean         @default(false)
  members      ProjectMember[]
  milestones   Milestone[]
  files        ProjectFile[]
  discussions  Discussion[]
  timeEntries  TimeEntry[]
  deliverables Deliverable[]
  tasks        Task[]
  messages     Message[]
  proposals    Proposal[]
  invoices     Invoice[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("projects")
}

model ProjectMember {
  id                String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role              String   @default("Member")
  allocationPercent Int      @default(100)
  assignedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([projectId, employeeId])
  @@map("project_members")
}

model Milestone {
  id          String          @id @default(uuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  status      MilestoneStatus @default(PENDING)
  progress    Int             @default(0)
  isDeleted   Boolean         @default(false)
  tasks       Task[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("milestones")
}

model ProjectFile {
  id           String     @id @default(uuid())
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mediaAssetId String
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  fileCategory String     @default("OTHER")
  version      Int        @default(1)
  uploadedById String?
  uploadedBy   User?      @relation("ProjectFileUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  isDeleted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("project_files")
}

model Discussion {
  id        String            @id @default(uuid())
  projectId String
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User              @relation("DiscussionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  mentions  Json?
  isDeleted Boolean           @default(false)
  replies   DiscussionReply[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("discussions")
}

model DiscussionReply {
  id           String     @id @default(uuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation("ReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content      String
  mentions     Json?
  isDeleted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("discussion_replies")
}

model TimeEntry {
  id         String    @id @default(uuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startTime  DateTime
  endTime    DateTime?
  duration   Int?
  notes      String?
  isDeleted  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("time_entries")
}

model Deliverable {
  id             String            @id @default(uuid())
  projectId      String
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  version        String            @default("1.0")
  status         DeliverableStatus @default(DRAFT)
  approvalStatus String            @default("PENDING")
  feedback       String?
  dueDate        DateTime?
  fileUrl        String?
  isDeleted      Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("deliverables")
}

model CalendarEvent {
  id          String            @id @default(uuid())
  title       String
  description String?
  type        CalendarEventType @default(OTHER)
  startAt     DateTime
  endAt       DateTime?
  isAllDay    Boolean           @default(false)
  isRecurring Boolean           @default(false)
  recurrence  Json?
  projectId   String?
  milestoneId String?
  createdById String?
  createdBy   User?             @relation("CalendarCreator", fields: [createdById], references: [id], onDelete: SetNull)
  isDeleted   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("calendar_events")
}

// ─────────────────────────────────────────────────────────
// Phase 5 — Simple Task Management
// ─────────────────────────────────────────────────────────

enum TaskStatus {
  TODO
  DOING
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id           String           @id @default(uuid())
  projectId    String
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId  String?
  milestone    Milestone?       @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  title        String
  description  String?
  status       TaskStatus       @default(TODO)
  priority     TaskPriority     @default(MEDIUM)
  assigneeId   String?
  assignee     User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  dueDate      DateTime?
  completedAt  DateTime?
  createdById  String?
  createdBy    User?            @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById  String?
  updatedBy    User?            @relation("TaskUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  isDeleted    Boolean          @default(false)
  comments     TaskComment[]
  attachments  TaskAttachment[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime @default(now())

  @@map("task_comments")
}

model TaskAttachment {
  id           String     @id @default(uuid())
  taskId       String
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  mediaAssetId String
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@map("task_attachments")
}

model Message {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  content     String
  attachments Json?    // array of URLs
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("messages")
}

// ─────────────────────────────────────────────────────────
// Phase 6.5 — Business Essentials
// ─────────────────────────────────────────────────────────

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

model Quote {
  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  services      Json      // array of service details/cost estimates
  estimatedCost Float
  notes         String?
  expiry        DateTime
  isConverted   Boolean   @default(false)
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("quotes")
}

model Proposal {
  id             String         @id @default(uuid())
  proposalNumber String         @unique
  clientId       String
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  scopeOfWork    String?
  timeline       String?
  deliverables   Json?          // list of deliverables/cost items
  price          Float
  currency       String         @default("USD")
  tax            Float          @default(0)
  discount       Float          @default(0)
  validUntil     DateTime
  status         ProposalStatus @default(DRAFT)
  isDeleted      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("proposals")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  amount        Float
  tax           Float         @default(0)
  discount      Float         @default(0)
  total         Float
  status        InvoiceStatus @default(DRAFT)
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("invoices")
}




